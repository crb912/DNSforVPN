#!/bin/sh /etc/rc.common
# dnsforvpn procd init script

START=99
STOP=10
USE_PROCD=1

PROG=/usr/bin/dnsforvpn
CONF=/etc/dnsforvpn/config.toml

start_service() {
	procd_open_instance dnsforvpn
	procd_set_param command "$PROG" --config "$CONF" --no-browser
	# respawn: threshold(s) delay(s) retry-count (0 = forever)
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	# restart when the config file changes
	procd_set_param file "$CONF"
	procd_close_instance
}
